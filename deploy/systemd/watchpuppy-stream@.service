[Unit]
Description=WatchPuppy MJPEG stream server for camera %i
Wants=network-online.target
After=network-online.target

[Service]
Type=simple
User=moai
WorkingDirectory=/home/moai/Workspace/Codex/WatchPuppy
EnvironmentFile=/home/moai/Workspace/Codex/WatchDog/configs/watchdog-tapo.env
EnvironmentFile=/home/moai/Workspace/Codex/WatchPuppy/configs/watchpuppy.env
ExecStart=/usr/bin/env bash /home/moai/Workspace/Codex/WatchPuppy/scripts/run_watchpuppy_stream_service.sh %i
StandardOutput=journal
StandardError=journal
Restart=always
RestartSec=5
TimeoutStopSec=15

[Install]
WantedBy=multi-user.target
